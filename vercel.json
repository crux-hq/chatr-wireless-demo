{
  "buildCommand": "node scripts/build-web.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/storybook", "destination": "/storybook/index.html" },
    { "source": "/storybook/:path*", "destination": "/storybook/:path*" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
